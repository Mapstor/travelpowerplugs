{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/animations/(.*)\\.html",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Type",
          "value": "text/html"
        }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|ico|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/terms-of-use",
      "destination": "/terms"
    },
    {
      "source": "/contact-us",
      "destination": "/contact"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy"
    },
    {
      "source": "/about-me",
      "destination": "/about"
    },
    {
      "source": "/europe",
      "destination": "/continent/europe"
    },
    {
      "source": "/north-america",
      "destination": "/continent/north-america"
    },
    {
      "source": "/south-america",
      "destination": "/continent/south-america"
    },
    {
      "source": "/asia",
      "destination": "/continent/asia"
    },
    {
      "source": "/africa",
      "destination": "/continent/africa"
    },
    {
      "source": "/oceania",
      "destination": "/continent/oceania"
    }
  ],
  "functions": {
    "src/app/og/[country]/route.tsx": {
      "maxDuration": 10
    }
  }
}